# Server
PORT=3000

# Frontend: API base (set when frontend runs on another port than backend, e.g. Vite on 3001)
# VITE_API_ORIGIN=http://localhost:3000

# Telemetry (path to folder containing agent dirs and agents.json)
TELEMETRY_ROOT=./trading-live

# Kill switch
KILL_SWITCH_ACTIVE=false
KILL_SWITCH_MODE=block_all

# Reconciliation tolerances
RECON_QTY_TOLERANCE=1e-6
RECON_VALUE_TOLERANCE_USD=0.5
RECON_PNL_TOLERANCE=2

# Optional: risk exposure limit (USD)
RISK_EXPOSURE_LIMIT_USD=50000

# Stale threshold (minutes) for agent status
STALE_THRESHOLD_MINUTES=5

# Supervisor (agent process orchestrator) — check/restart interval
POLL_INTERVAL_MS=30000
# Python executable for agents if not set per-agent (optional)
# PYTHON_PATH=C:\path\to\python.exe
# Best: in agents.json set runtimePath to venv Python (e.g. .venv\Scripts\python.exe) or set pythonPath to site-packages so spawn finds deps.
# STALE_THRESHOLD_MS=900000
# DEBUG_TOKEN=optional_secret_for_supervisor_endpoints_in_production
