# Server
PORT=3000

# Frontend: API base (set when frontend runs on another port than backend, e.g. Vite on 3001)
# VITE_API_ORIGIN=http://localhost:3000

# Binance / Home dashboard: `agents.json` + agent dirs under this folder (default: <repo>/trading-live).
# Do not set TELEMETRY_ROOT to trading-live-woox — Home would then show WOO agents.
TELEMETRY_ROOT=./trading-live
# Optional explicit override (takes precedence over TELEMETRY_ROOT for trading-live API only):
# TRADING_LIVE_TELEMETRY_ROOT=./trading-live
# WOO tab reads WOOX_TELEMETRY_ROOT (default: <repo>/trading-live-woox); see Backend/woox/config.ts

# WOO Real isolated runtime (new tab)
WOO_REAL_ENABLED=false
# Vite nav/route visibility flag for frontend:
# VITE_WOO_REAL_ENABLED=true
# Optional explicit telemetry root (default: ./trading-live-woo-real)
# WOO_REAL_TELEMETRY_ROOT=./trading-live-woo-real
# Personal API credentials (never commit real values)
# WOO_REAL_API_KEY=
# WOO_REAL_API_SECRET=
# WOO_REAL_API_BASE=https://api.woox.io
# Enable signed private balance sync in woo_real paper agent:
# WOO_REAL_USE_PRIVATE_BALANCE_SYNC=true

# Bybit isolated runtime
BYBIT_ENABLED=false
# Frontend tab visibility:
# VITE_BYBIT_ENABLED=true
# Optional explicit telemetry root (default: ./trading-live-bybit)
# BYBIT_TELEMETRY_ROOT=./trading-live-bybit
# Bybit public testnet base
# BYBIT_API_BASE=https://api-testnet.bybit.com
# Preferred quote asset for Bybit spot universe simulation (EU-oriented setup: USDC)
# BYBIT_BOT_QUOTE_ASSET=USDC

# Kill switch
KILL_SWITCH_ACTIVE=false
KILL_SWITCH_MODE=block_all

# Reconciliation tolerances
RECON_QTY_TOLERANCE=1e-6
RECON_VALUE_TOLERANCE_USD=0.5
RECON_PNL_TOLERANCE=2

# Optional: risk exposure limit (USD)
RISK_EXPOSURE_LIMIT_USD=50000

# Stale threshold (minutes) for agent status
STALE_THRESHOLD_MINUTES=5

# Supervisor (agent process orchestrator) — check/restart interval
POLL_INTERVAL_MS=30000
# Python executable for agents if not set per-agent (optional)
# PYTHON_PATH=C:\path\to\python.exe
# Linux example:
# PYTHON_PATH=/usr/bin/python3
# Best: in agents.json set runtimePath to venv Python (e.g. .venv\Scripts\python.exe) or set pythonPath to site-packages so spawn finds deps.
# STALE_THRESHOLD_MS=900000
# DEBUG_TOKEN=optional_secret_for_supervisor_endpoints_in_production
